# JDBC URL for Spring Boot (use jdbc:postgresql://... for local Postgres or Neon).
# Local example:
# SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/realtimeboard?sslmode=disable
# SPRING_DATASOURCE_USERNAME=your_local_user
# SPRING_DATASOURCE_PASSWORD=
#
# Neon example (use your values; do NOT commit them):
# SPRING_DATASOURCE_URL=jdbc:postgresql://<host>/<db>?sslmode=require
# SPRING_DATASOURCE_USERNAME=<user>
# SPRING_DATASOURCE_PASSWORD=<password>
SPRING_DATASOURCE_URL=
SPRING_DATASOURCE_USERNAME=
SPRING_DATASOURCE_PASSWORD=

# Or set standard Spring env names; see https://docs.spring.io/spring-boot/reference/application-properties.html

JWT_SECRET=change-me-to-a-long-random-string-at-least-32-characters
CORS_ALLOWED_ORIGINS=http://localhost:5173
PORT=8080
